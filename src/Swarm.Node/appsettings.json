{
  "ClusterUrl": "http://localhost:5000",
  "_comment": "ApiKey, RabbitMQ, and Database below are local-dev defaults. Override every secret value in production via environment variables (see docs/getting-started.md). ApiKey must be supplied via env (`ApiKey=...`) — the committed value is intentionally blank.",
  "ApiKey": "",
  "RabbitMQ": {
    "Hostname": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Database": {
    "ConnectionString": "DataSource=Data/app.db;Cache=Shared"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.RabbitMQ"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/node-.txt",
          "rollingInterval": "Day",
          "fileSizeLimitBytes": 104857600,
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "Swarm.Node"
    }
  },
  "Heartbeat": {
    "IntervalSeconds": 30
  },
  "ASPNETCORE_ENVIRONMENT": "Development",
  "SWARM_TASKENV_LOKENV": 1,
  "Swarm": {
    "PluginsPath": "plugins"
  }
}
